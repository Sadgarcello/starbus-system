# Copy to .env and adjust. UI: http://127.0.0.1:<PORT>/worker  http://127.0.0.1:<PORT>/admin
PORT=4001

# MariaDB / MySQL connection (local XAMPP or cloud)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=starbus

# TLS to MySQL (Railway/public cloud from Render: auto-enabled when RENDER=true and DB_HOST is not localhost).
# Force on: DB_SSL=1   Force off: DB_SSL=0
# DB_SSL=1

# JWT (required; server will not start without JWT_SECRET)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS (comma-separated). Leave empty to allow any origin (single-origin deploy).
# Example: http://localhost:5500,http://127.0.0.1:5500
CORS_ORIGINS=

# WhatsApp (digits only, country code first). Used by the public customer page.
# Example: 249113568408
WHATSAPP_NUMBER=249113568408

# Trust first reverse proxy so rate limits see real client IP (Render etc.). Set TRUST_PROXY=0 to disable.
# TRUST_PROXY=0

# All /api/public requests per IP (default 120 per minute). Stops basic scraping/flooding.
# PUBLIC_GLOBAL_WINDOW_MS=60000
# PUBLIC_GLOBAL_MAX=120
# PUBLIC_GLOBAL_LIMIT_DISABLED=0

# Legacy: was used when POST /api/public/bookings/reserve* created rows. Those routes now return 403.
# RESERVE_RATE_LIMIT_MAX=12
# RESERVE_RATE_LIMIT_WINDOW_MS=600000
# RESERVE_RATE_LIMIT_DISABLED=0
